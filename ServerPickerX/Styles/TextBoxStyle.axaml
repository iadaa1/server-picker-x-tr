<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <Border Padding="20" Background="Gray">
            <!-- Add Controls for Previewer Here -->
            <StackPanel Orientation="Horizontal" Spacing="12">
				<TextBox Classes="search-textbox" Width="128" Padding="20" Text="Test"/>
            </StackPanel>
        </Border>
    </Design.PreviewWith>

    <!-- Add Styles Here -->
    
    <Style Selector="TextBox.search-textbox">
        <Setter Property="BorderBrush" Value="#575cd4"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background">
            <Setter.Value>
				<SolidColorBrush Color="#4a4e8a" Opacity="0.5" />
            </Setter.Value>
        </Setter> 
        <Setter Property="FontSize" Value="14"/>

        <!-- set style when hovered or focused -->
        <Style Selector="^:focus /template/ Border#PART_BorderElement">
	        <Setter Property="BorderBrush" Value="{TemplateBinding BorderBrush}"/> 
            <Setter Property="Background" Value="{TemplateBinding Background}"/>
        </Style>

        <Style Selector="^:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="BorderBrush" Value="{TemplateBinding BorderBrush}"/> 
            <Setter Property="Background" Value="{TemplateBinding Background}"/>
        </Style>
    </Style>
</Styles>
