<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ServerPickerX.App"
             xmlns:local="using:ServerPickerX"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->
    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
		<ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
				<ResourceInclude Source="/Locales/Locale_en-us.axaml" />
				<ResourceInclude Source="/Locales/Locale_es-es.axaml" />
				<ResourceInclude Source="/Locales/Locale_zh-cn.axaml" />
				<ResourceInclude Source="/Locales/Locale_ja-jp.axaml" />
				<ResourceInclude Source="/Locales/Locale_sv-se.axaml" />
				<ResourceInclude Source="/Locales/Locale_ru-ru.axaml" />
				<ResourceInclude Source="/Locales/Locale_de-de.axaml" />
				<ResourceInclude Source="/Locales/Locale_pl-pl.axaml" />
				<ResourceInclude Source="/Locales/Locale_tr-tr.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <StyleInclude Source="/Styles/TitleBarButtonStyle.axaml" />
        <StyleInclude Source="/Styles/MainButtonStyle.axaml" />
        <StyleInclude Source="/Styles/TextBoxStyle.axaml" />
        <StyleInclude Source="/Styles/ComboBoxStyle.axaml" />
    </Application.Styles>
</Application>
