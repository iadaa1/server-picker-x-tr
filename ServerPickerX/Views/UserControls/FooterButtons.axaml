<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:i="https://github.com/projektanker/icons.avalonia"
             mc:Ignorable="d"
             x:Class="ServerPickerX.FooterButtons">
    <StackPanel
        VerticalAlignment="Center"
        HorizontalAlignment="Right"
        Orientation="Horizontal"
        Spacing="6">
        <Button Foreground="White" i:Attached.Icon="fa-paypal" FontSize="20" />
        <Button Foreground="White" i:Attached.Icon="fa-github" FontSize="20" />
        <Button Foreground="White" i:Attached.Icon="fa-gear" FontSize="20" Margin="0,0,10,0" />
    </StackPanel>
</UserControl>
