<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:userControls="using:ServerPickerX"
    xmlns:constants="clr-namespace:ServerPickerX.Constants"
    xmlns:viewmodels="using:ServerPickerX.ViewModels"
    mc:Ignorable="d"
    Width="400"
    Height="250"
    x:Class="ServerPickerX.SettingsWindow"
    x:DataType="viewmodels:SettingsWindowViewModel"
    SystemDecorations="BorderOnly"
    ExtendClientAreaToDecorationsHint="True"
    ExtendClientAreaChromeHints="NoChrome"
    ExtendClientAreaTitleBarHeightHint="-1"
    WindowStartupLocation="CenterOwner"
    CanResize="False"
    CanMaximize="False"
    Background="Transparent"
    Loaded="Window_Loaded">
    <Window.Styles>
        <Style Selector="Border.wBorder">
            <Style.Animations>
                <Animation Duration="0:0:0.3" Easing="QuadraticEaseIn">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="0"/>
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="1.0"/>
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <Border 
        Classes="wBorder" 
        Background="#373B78"
        BorderBrush="#575cd4"
        BorderThickness="1.35">
        <Grid>
            <Grid.RowDefinitions>
                <!-- Title Bar -->
                <RowDefinition Height="30" />
                <!-- Main Content -->
                <RowDefinition />
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Grid x:Name="TitleBar" 
                  Background="#373B78" 
                  PointerPressed="TitleBar_PointerPressed">
                <TextBlock 
                    VerticalAlignment="Center" 
                    Margin="10,0,0,0" 
                    Foreground="White" 
                    FontWeight="Bold" 
                    FontSize="14">
                    Settings
                </TextBlock>
                <userControls:TitleBarButtons/>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition Height="72" />
                </Grid.RowDefinitions>

                <!-- Main settings -->
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <CheckBox 
                            x:Name="VersionCheckerSetting"
                            Foreground="White"
                            IsChecked="{Binding VersionCheckOnStartup}"
                            Command="{Binding VersionCheckerToggleCommand}"
                            Content="{DynamicResource CheckForNewVersion}"/>
                    </StackPanel>
                </Grid>

                <!-- Bottom settings -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <ComboBox 
                            x:Name="LanguageComboBox"
                            Classes="game-combobox"
                            Width="154" 
                            Height="34"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MinWidth="100"
                            MaxWidth="200"
                            ItemsSource="{Binding Source={x:Static constants:Locales.All}}"
                            SelectedIndex="0"
                            SelectionChanged="LanguageComboBox_SelectionChanged"
                            ToolTip.Tip="{DynamicResource LanguageComboBoxToolTip}"
                            ToolTip.ShowDelay="20">
                        </ComboBox>
                    </Grid>
                    <Grid Grid.Column="1">
                        <Button 
                            Classes="main-btn" 
                            HorizontalAlignment="Center"
                            MinWidth="100"
                            MaxWidth="200"
                            Command="{Binding ResetFirewallCommand}"
                            Content="{DynamicResource ResetFirewall}"
                            ToolTip.Tip="{DynamicResource ResetFirewallToolTip}"
                            ToolTip.ShowDelay="20"/>
                    </Grid>
                </Grid>
            </Grid>

            <Canvas>
                <TextBlock 
                    x:Name="VersionTextBlock"
                    Canvas.Top="234"
                    Canvas.Right="2"
                    ZIndex="-2"
                    Text="Version: " 
                    Foreground="White"
                    FontSize="10"/>
            </Canvas>
        </Grid>
    </Border>
</Window>
